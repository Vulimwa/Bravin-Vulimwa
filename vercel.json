{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/css/(.*)",
      "destination": "/css/$1"
    },
    {
      "source": "/js/(.*)",
      "destination": "/js/$1"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/pages/$1"
    }
  ],
  "redirects": [
    {
      "source": "/includes/(.*)",
      "destination": "/pages/404.html",
      "statusCode": 404
    },
    {
      "source": "/template/(.*)",
      "destination": "/pages/404.html",
      "statusCode": 404
    }
  ]
}
